# Copy this file to .env and fill in the values

# Database
DB_NAME=plant_db
DB_USER=plant_user
DB_PASSWORD=plant_pass
DB_PORT=5433

# PgAdmin
PGADMIN_EMAIL=admin@plantmanager.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# APIs (get your token at https://trefle.io)
TREFLE_API_TOKEN=your-trefle-token-here

# Dev email (Gmail App Password)
DEV_MAIL_FROM=your-email@gmail.com
DEV_MAIL_USERNAME=your-email@gmail.com
DEV_MAIL_PASSWORD=your-gmail-app-password

# Firebase (place your service account JSON at project root as firebase-service-account.json)
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json

# MCP
MCP_API_KEY=your-mcp-api-key
MCP_DEFAULT_USER_EMAIL=default@example.com

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# OpenWeatherMap
OPENWEATHER_API_KEY=your-openweather-key
